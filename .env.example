# Autonomous Executive Email Copilot — environment configuration
# Copy to `.env` and fill in. The app runs without any of these (it falls back
# to the deterministic baseline policy), but LLM/hybrid modes need a provider.

# =============================================================================
# LLM provider — pick ONE of the two styles below (Azure OpenAI is easiest).
# The app runs without any provider (it falls back to the deterministic baseline
# policy); LLM/hybrid modes and the benchmark `llm` agent need one.
# =============================================================================

# --- Style A: Azure OpenAI (recommended) -------------------------------------
# Set these standard AZURE_OPENAI_* names and the app derives the base URL, key,
# version, and model automatically — no need to set Style B as well.
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# Optional, only if you use embeddings:
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# --- Style B: OpenAI / OpenAI-compatible / manual --------------------------
# Standard OpenAI (or compatible) key. For Azure you can instead use Style A above.
OPENAI_API_KEY=
# Hugging Face token (used as a fallback for OPENAI_API_KEY when set).
# NOTE: HF_TOKEN takes precedence over OPENAI_API_KEY — leave blank for Azure.
HF_TOKEN=
# Base URL. For Azure (manual style) include /openai/deployments/<deployment>.
API_BASE_URL=https://api.openai.com/v1
# Primary (small/cheap) model tried first.
MODEL_NAME=gpt-4o-mini
# Larger model used as a fallback when confidence is low.
LARGER_MODEL=gpt-4o
# Confidence below which the agent retries with LARGER_MODEL (0..1).
CONFIDENCE_THRESHOLD=0.7
# Azure OpenAI API version (manual style; AZURE_OPENAI_API_VERSION wins for Style A).
AZURE_API_VERSION=2024-02-15-preview

# --- Database ---
# Optional SQLAlchemy database URL. Leave blank to use the zero-config local
# SQLite database (the default; no extra dependencies required).
# To run on Postgres, set a URL and install the optional driver:
#   pip install "psycopg[binary]"   # SQLAlchemy 2.x psycopg3 driver
# then e.g.:
#   DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/email_copilot
# (psycopg2 also works: postgresql+psycopg2://... with `pip install psycopg2-binary`.)
# Non-SQLite URLs enable connection pooling (pool_pre_ping, pool_recycle,
# pool_size, max_overflow). psycopg is NOT a hard dependency and is imported
# only when a Postgres URL is used.
DATABASE_URL=

# --- Behavior ---
# Require human approval before reply/escalate actions (true/false/1/0/yes/no).
# Off by default; turn on for the human-in-the-loop product flow.
REQUIRE_APPROVAL=false

# --- Security (all opt-in; the API runs open by default) ---
# If set, mutating routes (POST/PUT/PATCH/DELETE) require this token via
# `Authorization: Bearer <token>` or `X-API-Key`. Leave blank to run open.
API_AUTH_TOKEN=
# Comma-separated allowed CORS origins. "*" allows all (default).
CORS_ORIGINS=*
# Max requests per client IP per minute. 0 disables rate limiting (default).
RATE_LIMIT_PER_MINUTE=0

# --- Dashboard (React) ---
# Base URL the dashboard uses to reach the API.
APP_API_BASE_URL=http://localhost:8000

# --- Logging ---
# Root log level: DEBUG | INFO | WARNING | ERROR. Defaults to INFO.
LOG_LEVEL=INFO
