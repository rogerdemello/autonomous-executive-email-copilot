# Build context exclusions — keep the image small and builds fast.
.git
.github
.venv
venv
**/__pycache__
*.pyc
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov

# Node / dashboard (the image builds the dashboard in a separate stage)
dashboard/node_modules
dashboard/dist

# Local runtime state and artifacts
*.db
*.sqlite
*.sqlite3
data/*.db
env/data/*.db
artifacts
leaderboard*.csv

# Local env and editor files
.env
.env.*
!.env.example
.idea
.vscode
.sisyphus
