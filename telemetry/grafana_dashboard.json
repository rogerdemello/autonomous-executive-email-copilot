{
  "dashboard": {
    "title": "Autonomous Executive Email Copilot",
    "uid": "exec-email-copilot",
    "tags": ["telemetry", "metrics"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Total Requests",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "requests_total",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "title": "Active Episodes",
        "type": "stat",
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "active_episodes",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Episodes Completed",
        "type": "stat",
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "episodes_completed_total",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Episodes Failed",
        "type": "stat",
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "episodes_failed_total",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "API Errors",
        "type": "stat",
        "gridPos": {"x": 0, "y": 4, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "api_errors_total",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "Tokens Used",
        "type": "stat",
        "gridPos": {"x": 6, "y": 4, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "tokens_used_total",
            "refId": "A"
          }
        ]
      },
      {
        "id": 7,
        "title": "Total Cost (USD)",
        "type": "stat",
        "gridPos": {"x": 12, "y": 4, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "cost_usd_total",
            "refId": "A"
          }
        ]
      },
      {
        "id": 8,
        "title": "Request Duration (ms)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
        "targets": [
          {
            "expr": "rate(request_duration_ms_sum[5m]) / rate(request_duration_ms_count[5m])",
            "refId": "A"
          }
        ]
      },
      {
        "id": 9,
        "title": "Failure Rate",
        "type": "gauge",
        "gridPos": {"x": 0, "y": 16, "w": 8, "h": 8},
        "targets": [
          {
            "expr": "episodes_failed_total / (episodes_completed_total + episodes_failed_total)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.2, "color": "yellow"},
                {"value": 0.5, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Error Rate",
        "type": "gauge",
        "gridPos": {"x": 8, "y": 16, "w": 8, "h": 8},
        "targets": [
          {
            "expr": "api_errors_total / requests_total",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.1, "color": "yellow"},
                {"value": 0.3, "color": "red"}
              ]
            }
          }
        }
      }
    ]
  },
  "alertRules": [
    {
      "name": "High Failure Rate",
      "condition": "episodes_failed_total / (episodes_completed_total + episodes_failed_total) > 0.2",
      "for": "5m",
      "labels": {"severity": "critical"},
      "annotations": {"description": "Episode failure rate exceeded 20%"}
    },
    {
      "name": "High API Error Rate",
      "condition": "api_errors_total / requests_total > 0.1",
      "for": "5m",
      "labels": {"severity": "warning"},
      "annotations": {"description": "API error rate exceeded 10%"}
    },
    {
      "name": "Cost Spike",
      "condition": "cost_usd_total > 100",
      "for": "0m",
      "labels": {"severity": "warning"},
      "annotations": {"description": "Total cost exceeded $100"}
    }
  ]
}